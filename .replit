modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 240000

[userenv]

[userenv.shared]
TRUMEDIA_USERNAME = "jmarucc@lsu.edu"
TRUMEDIA_SITENAME = "LSU-NCAA-CFB"

[nix]
channel = "stable-25_05"
